          <mxGeometry x="1285" y="870" width="140" height="75" as="geometry" />
        </mxCell>
        <mxCell id="legend" value="&lt;b&gt;色分けの凡例&lt;/b&gt;&#xa;&lt;font color=&quot;#5E35B1&quot;&gt;■&lt;/font&gt; メインClaude　&lt;font color=&quot;#1976D2&quot;&gt;■&lt;/font&gt; スキル　&lt;font color=&quot;#388E3C&quot;&gt;■&lt;/font&gt; サブエージェント　&lt;font color=&quot;#F57C00&quot;&gt;■&lt;/font&gt; フック　&lt;font color=&quot;#C2185B&quot;&gt;■&lt;/font&gt; MCP　&lt;font color=&quot;#F9A825&quot;&gt;■&lt;/font&gt; ドキュメント　&lt;font color=&quot;#616161&quot;&gt;■&lt;/font&gt; 外部" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9E6;strokeColor=#B8860B;fontSize=11;align=left;verticalAlign=middle;spacingLeft=12" vertex="1" parent="1">
          <mxGeometry x="40" y="830" width="700" height="60" as="geometry" />
        </mxCell>
        <mxCell id="keypoints" value="&lt;b&gt;★ 読み取るポイント&lt;/b&gt;&#xa;・&lt;b&gt;メインClaude が全体のハブ&lt;/b&gt;。ユーザーからの /xxx 入力を受け、スキル手順を読み、必要に応じてサブエージェントに委譲する&#xa;・&lt;b&gt;フックは Claude の意思と無関係&lt;/b&gt;に自動発火する。致命的チェック(型/DBバックアップ)はフックで強制する&#xa;・&lt;b&gt;MCP は外部ツールとの境界&lt;/b&gt;。Playwright MCP を介して browser-tester がブラウザを実機操作&#xa;・&lt;b&gt;ドキュメントが設計書駆動の要&lt;/b&gt;。.claude/ は方針・パターン、docs/設計書/ は実態(コード同期)として分離&#xa;・&lt;b&gt;L規模は2段階設計&lt;/b&gt;。Stage 1 レビューで code-reviewer + product-advisor を並列実行（役割分担: 設計整合性&amp;UI設計 / 企画&amp;UX体験）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9E6;strokeColor=#B8860B;fontSize=11;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="40" y="895" width="700" height="145" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
