# =============================================================================
# 環境変数サンプル（このファイルはコミット対象。実値は .env.local に書く）
# =============================================================================
#
# Phase 9（クラウド同期 + Google OAuth）から下記の変数が必要になる。
# 設計書: docs/features/20260504_phase9-cloud-sync.md §4-2
#
# 使い方:
#   1. このファイルを .env.local にコピー
#      cp .env.example .env.local
#   2. 各変数の値を実値に書き換える
#   3. .env.local は .gitignore 対象なのでコミットされない
#
# -----------------------------------------------------------------------------

# PostgreSQL 接続文字列
# Vercel + Neon / Supabase などの無料 PostgreSQL を想定。
# 接続プール枯渇を避けるため、Serverless 環境では connection_limit と pool_timeout
# クエリパラメータを必ず付与すること（Neon 無料枠は同時接続 10 まで）。
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?connection_limit=5&pool_timeout=10"

# Auth.js v5 のセッション暗号化キー
# 下記コマンドで生成: openssl rand -base64 32
AUTH_SECRET="REPLACE_WITH_BASE64_32BYTES"

# アプリケーションの公開 URL
# 開発: http://localhost:3000
# 本番: https://your-app.vercel.app など。Vercel デプロイ時は自動で設定される
AUTH_URL="http://localhost:3000"

# Google OAuth クライアント認証情報
# 取得方法: Google Cloud Console → API とサービス → 認証情報 → OAuth クライアント ID 作成
# 承認済みリダイレクト URI には {AUTH_URL}/api/auth/callback/google を追加すること
AUTH_GOOGLE_ID="REPLACE_WITH_GOOGLE_OAUTH_CLIENT_ID"
AUTH_GOOGLE_SECRET="REPLACE_WITH_GOOGLE_OAUTH_CLIENT_SECRET"
