{
  "effortLevel": "high",
  "env": {
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "500000"
  },
  "permissions": {
    "deny": [
      "Read(/mnt/**)",
      "Edit(/mnt/**)",
      "Write(/mnt/**)",
      "Bash(*/mnt/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pre-migrate-backup.js",
            "timeout": 60,
            "statusMessage": "Checking if DB backup is needed..."
          },
          {
            "type": "command",
            "command": "node .claude/hooks/pre-commit-type-check.js",
            "timeout": 120,
            "statusMessage": "Checking if type check is needed..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/post-commit-doc-check.js",
            "timeout": 10,
            "statusMessage": "Checking doc sync..."
          }
        ]
      }
    ]
  }
}
